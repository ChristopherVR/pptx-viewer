{
	"name": "pptx-viewer",
	"version": "1.0.0",
	"description": "React-based PowerPoint viewer, editor, and canvas export — depends on pptx-viewer-core",
	"main": "dist/index.mjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./viewer": {
			"types": "./dist/viewer/index.d.ts",
			"import": "./dist/viewer/index.mjs",
			"require": "./dist/viewer/index.js"
		},
		"./styles": "./dist/pptx-viewer.css",
		"./styles.css": "./dist/pptx-viewer.css",
		"./theme.css": "./src/styles/theme.css"
	},
	"scripts": {
		"build": "tsup && npx @tailwindcss/cli -i src/styles/pptx-viewer.css -o dist/pptx-viewer.css --minify",
		"build:css": "npx @tailwindcss/cli -i src/styles/pptx-viewer.css -o dist/pptx-viewer.css --minify",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit --pretty",
		"test": "vitest run",
		"test:watch": "vitest",
		"pack": "bun run build && bun pm pack"
	},
	"dependencies": {
		"pptx-viewer-core": "workspace:*",
		"emf-converter": "workspace:*",
		"mtx-decompressor": "workspace:*",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.5.0"
	},
	"bundledDependencies": [
		"pptx-viewer-core",
		"emf-converter",
		"mtx-decompressor"
	],
	"peerDependencies": {
		"fast-xml-parser": "^5.5.5",
		"framer-motion": "^12.36.0",
		"html2canvas": "^1.4.1",
		"i18next": "^25.8.18",
		"jszip": "^3.10.1",
		"jspdf": "^4.2.0",
		"lucide-react": "^0.577.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "^16.5.8",
		"react-icons": "^5.6.0"
	},
	"optionalDependencies": {
		"three": ">=0.160.0",
		"@react-three/fiber": ">=8.0.0",
		"@react-three/drei": ">=9.0.0",
		"yjs": ">=13.0.0",
		"y-websocket": ">=2.0.0"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.2.1",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0",
		"yjs": "^13.6.30",
		"y-websocket": "^3.0.0"
	},
	"files": [
		"dist/",
		"README.md"
	],
	"keywords": [
		"pptx",
		"powerpoint",
		"viewer",
		"editor",
		"react",
		"openxml",
		"presentation"
	],
	"license": "MIT"
}
